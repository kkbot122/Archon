# =========================
# Archon Monorepo .gitignore
# =========================

# -------------------------
# OS / Editor
# -------------------------
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# -------------------------
# Go (Gateway & Stitcher)
# -------------------------
bin/
vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
# (Note: We intentionally DO NOT ignore generated protobuf files like *.pb.go. 
# It is best practice to commit them so CI/CD doesn't need protoc installed.)

# -------------------------
# Python (AI Brain)
# -------------------------
services/ai-brain/venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.tox/

# -------------------------
# Node.js / Next.js (Frontend)
# -------------------------
node_modules/
.next/
out/
build/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------
# Terraform / Infrastructure
# -------------------------
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
*.tfvars.json
crash.log

# -------------------------
# Secrets & Environment Variables
# -------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
secrets.json